        "for i, row in df.iterrows():\n",
        "\n",
        "    img_path = os.path.join(DATA_DIR, row[\"filename\"])\n",
        "\n",
        "    try:\n",
        "        image = Image.open(img_path).convert(\"L\")\n",
        "        image = transform(image)\n",
        "\n",
        "        X.append(image)\n",
        "        y.append(row[\"gender\"])\n",
        "        races.append(row[\"race\"])\n",
        "    except Exception as e:\n",
