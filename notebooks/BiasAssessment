        "    plt.axis('off')\n",
        "\n",
        "    plt.subplot(1, 3, 3)\n",
        "    # Show absolute difference to highlight perturbation\n",
        "    plt.imshow(np.abs(X_test_subset[0].numpy() - X_adv[0].numpy()).squeeze(), cmap='hot')\n",
